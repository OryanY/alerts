SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=master
SQL_USER=sa
SQL_PASSWORD=YOUR_SQL_PASSWORD
SQL_ENCRYPT=false
MONGO_USER=grafana2sn
MONGO_PASSWORD=YOUR_MONGO_PASSWORD
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=grafana_snow_dev
MONGO_AUTH_DB=admin
SERVICENOW_USERNAME=YOUR_SERVICENOW_USERNAME
SERVICENOW_PASSWORD=YOUR_SERVICENOW_PASSWORD
SERVICENOW_URL=https://your-instance.service-now.com
SERVICENOW_URL_DEV=http://localhost:8000
NODE_TLS_REJECT_UNAUTHORIZED=0
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ADMIN_SECRET=YOUR_ADMIN_SECRET

# ServiceNow Reference Data Configuration
SN_GROUP_TABLE=sys_user_group
SN_GROUP_QUERY=active=true^u_unit=80
SN_GROUP_FIELDS=sys_id,name

SN_OFFERING_TABLE=service_offering
SN_OFFERING_QUERY=active=true
SN_OFFERING_FIELDS=sys_id,name

SN_BUSINESS_TABLE=cmdb_ci_service
SN_BUSINESS_QUERY=active=true
SN_BUSINESS_FIELDS=sys_id,name

# Business Service (parent) -> Service Offering (child) relationships, from cmdb_ci_rel.
# All values are intentionally overridable — CMDB rel types / network coverage vary by instance.
SN_REL_TABLE=cmdb_ci_rel
# Plain ref → sys_id (stored); dot-walked .name → display name (shown).
SN_REL_FIELDS=parent,parent.name,child,child.name
# Narrow to the relationship type that links Business Services to Offerings, e.g.
#   SN_REL_TYPE_QUERY=type.name=Depends on::Used by
# Leave blank to return all relationships (bounded to 1000 rows).
SN_REL_TYPE_QUERY=
# {network} is substituted with the chosen network. Default keeps CIs with no network set.
SN_REL_NETWORK_FILTER=parent.u_network_ciLIKE{network}^ORchild.u_network_ciLIKE{network}^ORparent.u_network_ciISEMPTY
# Network preselected in the mapping form (analyst can override).
SN_DEFAULT_NETWORK=

# Fields ServiceNow makes mandatory once a Service Offering is selected
# (e.g. OpenShift -> deployment link). Read from UI + Data policies whose
# condition references the offering's sys_id. All overridable per instance.
SN_UI_POLICY_TABLE=sys_ui_policy
SN_UI_POLICY_QUERY=active=true^table=incident
SN_UI_POLICY_ACTION_TABLE=sys_ui_policy_action
SN_DATA_POLICY_TABLE=sys_data_policy
SN_DATA_POLICY_QUERY=active=true^model_table=incident
SN_DATA_POLICY_RULE_TABLE=sys_data_policy_rule

INCIDENT_SETTINGS_KEY=tequila
